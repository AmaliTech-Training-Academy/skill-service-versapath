{
  "family": "versapath-skill-service",
  "taskRoleArn": "arn:aws:iam::697863031884:role/versapath-ecs-task-role",
  "executionRoleArn": "arn:aws:iam::697863031884:role/versapath-ecs-task-execution-role",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "1024",
  "memory": "2048",
  "containerDefinitions": [
    {
      "name": "skill-service",
      "image": "697863031884.dkr.ecr.eu-west-1.amazonaws.com/versapath/skill-service:latest",
      "cpu": 0,
      "portMappings": [
        {
          "containerPort": 8100,
          "hostPort": 8100,
          "protocol": "tcp",
          "name": "skill-service"
        }
      ],
      "essential": true,
      "environment": [
        {
          "name": "SERVER_PORT",
          "value": "8100"
        },
        {
          "name": "SPRING_PROFILES_ACTIVE",
          "value": "docker"
        },
        {
          "name": "EUREKA_CLIENT_URL",
          "value": "http://service-discovery:8761/eureka"
        },
        {
          "name": "CONFIG_SERVER_URL",
          "value": "http://config-server:8888"
        },
        {
          "name": "SPRING_APPLICATION_NAME",
          "value": "skill-service"
        },
        {
          "name": "SPRING_REDIS_HOST",
          "value": "versapath-redis-public.qhppxi.cache.amazonaws.com"
        },
        {
          "name": "SPRING_REDIS_PORT",
          "value": "6379"
        },
        {
          "name": "SPRING_DATASOURCE_URL",
          "value": "jdbc:postgresql://versapath-rds-public.c74djmqdddtw.eu-west-1.rds.amazonaws.com:5432/versapath_db"
        },
        {
          "name": "SPRING_DATASOURCE_USERNAME",
          "value": "versapath_user"
        },
        {
          "name": "SPRING_DATASOURCE_PASSWORD",
          "value": "versapath2024"
        },
        {
          "name": "SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT",
          "value": "org.hibernate.dialect.PostgreSQLDialect"
        }
      ],
      "mountPoints": [],
      "volumesFrom": [],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/versapath/skill-service",
          "awslogs-region": "eu-west-1",
          "awslogs-stream-prefix": "skill-service"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "curl -f http://localhost:8100/actuator/health || exit 1"
        ],
        "interval": 30,
        "timeout": 15,
        "retries": 5,
        "startPeriod": 300
      },
      "systemControls": []
    }
  ],
  "volumes": [],
  "placementConstraints": []
}
